{
  "schema_version": "fusion_parametric_case.v2",
  "case_id": "b06_robot_arm_assembly",
  "title": "Parametric multi-component industrial robot arm",
  "complexity_tier": 6,
  "time_limit_minutes": 60,
  "maximum_autonomous_repairs": 2,
  "source_inspiration": {
    "name": "WorldSkills Lyon 2024 Skill 05 M1 Mechanical Design Challenge",
    "url": "https://worldskillsindia.co.in/world_skills_test_project_isc_2024.php",
    "adaptation": "Clean-room sixteen-component robot fixture; official solution and marking files remain oracle-only and are not redistributed."
  },
  "risk_domains": [
    "multi_component_additive_creation",
    "identity_occurrence_architecture",
    "parametric_kinematic_chain",
