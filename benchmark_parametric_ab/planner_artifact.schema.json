{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.fusion-agent.invalid/schemas/fusion_planner_artifact.v1.json",
  "title": "Frozen planner output for a causal CAD benchmark",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "arm_id",
    "case_id",
    "planner",
    "intent",
    "assumptions",
    "parameters",
    "build_graph",
    "verification_assertions",
    "script_sha256"
  ],
  "properties": {
    "schema_version": {"const": "fusion_planner_artifact.v1"},
    "arm_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,39}$"},
    "case_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,79}$"},
    "planner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model", "reasoning_profile"],
      "properties": {
        "provider": {"type": "string", "minLength": 1, "maxLength": 80},
        "model": {"type": "string", "minLength": 1, "maxLength": 120},
        "reasoning_profile": {"type": "string", "minLength": 1, "maxLength": 80}
      }
    },
    "intent": {"type": "string", "minLength": 1, "maxLength": 2000},
    "assumptions": {
      "type": "array",
      "maxItems": 100,
      "items": {"type": "string", "minLength": 1, "maxLength": 500}
    },
    "parameters": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "expression"],
        "properties": {
          "name": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,79}$"},
          "expression": {"type": "string", "minLength": 1, "maxLength": 200}
        }
      }
    },
    "build_graph": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "operation", "depends_on", "target_component", "inputs"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,79}$"},
          "operation": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,79}$"},
          "depends_on": {
            "type": "array",
            "uniqueItems": true,
            "maxItems": 100,
            "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,79}$"}
          },
          "target_component": {"type": "string", "minLength": 1, "maxLength": 300},
          "inputs": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "integer", "boolean", "null"]
            }
          }
        }
      }
    },
    "verification_assertions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "target", "operator", "expected"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,79}$"},
          "target": {"type": "string", "minLength": 1, "maxLength": 300},
          "operator": {
            "enum": ["eq", "ne", "approx", "gte", "lte", "contains", "unchanged", "increased_by", "decreased_by"]
          },
          "expected": {"type": ["string", "number", "integer", "boolean", "null"]},
          "tolerance": {"type": "number", "minimum": 0}
        },
        "allOf": [
          {
            "if": {"properties": {"operator": {"const": "approx"}}},
            "then": {"required": ["tolerance"]}
          }
        ]
      }
    },
    "script_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
